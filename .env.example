# Public app routing
PUBLIC_SITE_URL=https://network.shivworks.com
PUBLIC_SHIVWORKS_MAIN_SITE=https://shivworks.com
PUBLIC_SHIVWORKS_STORE_URL=https://shivworkspg.com
PUBLIC_SHIVWORKS_MEMBERSHIP_URL=https://shivworkspg.com/theshivworksnetwork/
PUBLIC_CIRCLE_COMMUNITY_URL=https://community.example.com

# Clerk
PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_JWT_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxx

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_BRONZE_PRICE_ID=price_xxx
STRIPE_VIP_PRICE_ID=price_xxx

# Email
RESEND_API_KEY=re_xxx
EMAIL_FROM=ShivWorks Network <noreply@network.shivworks.com>
PUBLIC_SUPPORT_EMAIL=network@shivworks.com
SUPPORT_EMAIL=network@shivworks.com

# Admins
SHIVWORKS_ADMIN_EMAILS=ops@shivworks.com

# Database
# When set, app uses Postgres. Otherwise it falls back to local SQLite.
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# DATABASE_PATH=/absolute/path/to/shivworks-network.db
