entrypoint = "package.json"
language = "nodejs"
modules = ["nodejs-20"]
hidden = [".git", ".next", ".svelte-kit", "node_modules", ".pnpm-store", ".wrangler"]
onBoot = "pnpm install --frozen-lockfile=false && pnpm exec svelte-kit sync"
run = "pnpm exec vite dev --host 0.0.0.0 --port 3000"

[gitHubImport]
requiredFiles = [".replit", "replit.nix", "replit.md", "package.json"]

[nix]
channel = "stable-24_05"

[[ports]]
localPort = 3000
externalPort = 80
